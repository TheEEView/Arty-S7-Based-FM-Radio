		(at 61.5 8.5 0)
		(layer "Cmts.User")
		(uuid "e6456bbd-2c36-41bf-afc4-46514dbaa7f8")
		(effects
			(font
				(size 1 1)
				(thickness 0.1)
			)
		)
	)
	(gr_text "TODO: \nAdd solid GND planes on layers 2/3\nGround via stitching\nDecisions:\nUse Coplanar Waveguide for RF filter section for more confined EM fields \nUse 0.6x0.3 vias\nUse 8mil trace with 0.05mm airgap assuming 1ounce copper, 4.6 dielectric constant\nUse 1mm via distance (2xgap)\nUse 2mm between vias horizontally\nfor microstrip with solid groundplane in layers 2,3 oriented horizontally for EM fields\nUse 0.4mm silkscreen width/height to balance readability/placement\nEnsure RF Mixer (U12) is far away from sensitive RF/analog front end"
		(at 49.7 6.6 0)
		(layer "Cmts.User")
		(uuid "edfbe10c-77da-42ab-ba23-7e0244f8ad0d")
		(effects
			(font
				(size 0.8 0.8)
				(thickness 0.1)
			)
			(justify left bottom)
		)
	)
